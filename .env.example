# Echo — Video conferencing by Facile
# Copy to .env and fill in the values

# Public URL (required — your Dokploy domain)
PUBLIC_URL=https://echo.facile.app

# Server IP (required — la ruche's public IP, for WebRTC media)
JVB_ADVERTISE_IPS=

# Config directory
CONFIG=./echo-config

# Timezone
TZ=Europe/Paris

# Ports
HTTP_PORT=8000
JVB_PORT=10000

# XMPP domains (defaults work fine, don't change unless needed)
XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_HIDDEN_DOMAIN=hidden.meet.jitsi
XMPP_RECORDER_DOMAIN=recorder.meet.jitsi
XMPP_PORT=5222
XMPP_SERVER=xmpp.meet.jitsi
XMPP_BOSH_URL_BASE=http://xmpp.meet.jitsi:5280

# JVB
JVB_AUTH_USER=jvb
JVB_BREWERY_MUC=jvbbrewery
JVB_STUN_SERVERS=meet-jit-si-turnrelay.jitsi.net:443

# Jitsi image version
JITSI_IMAGE_VERSION=stable

# Auth (uncomment to enable)
#ENABLE_AUTH=1
#ENABLE_GUESTS=1
#AUTH_TYPE=internal

# AI transcriptions (coming soon)
#ENABLE_TRANSCRIPTIONS=1

# Passwords (generate with: openssl rand -hex 16)
JICOFO_AUTH_PASSWORD=
JVB_AUTH_PASSWORD=
